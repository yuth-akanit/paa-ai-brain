    {
      "parameters": {
        "jsCode": "// Build replyPayload for Rich Menu commands (MENU:*)\nconst LIFF = String($json.LIFF_BOOK_URL || '').trim();\nconst replyToken = String($json.reply_token || '').trim();\nconst cmd = String($json.cmd || '').trim();\nconst headerColor = \"#06C755\";\n\nconst prices = [\n  { label: \"9,000 BTU\", price: \"700\" },\n  { label: \"12,000 - 13,000 BTU\", price: \"800\" },\n  { label: \"18,000 BTU\", price: \"900\" },\n  { label: \"24,000 BTU\", price: \"1,000\" },\n];\nconst addons = [\n  { item: \"น้ำยาฆ่าเชื้อ (ล้างคอยล์)\", price: \"+100\" },\n  { item: \"ระบบ Inverter\", price: \"+100\" },\n  { item: \"ตรวจเช็ค/ประเมินหน้างาน\", price: \"1,000+\", note: \"กรณีเช็คแล้วไม่ซ่อม\" },\n];\n\nconst postbackAction = (label, data) => ({ type: \"postback\", label, data });\n\nfunction genPriceFlex() {\n  const priceRows = prices.map((p) => ({\n    type: \"box\",\n    layout: \"horizontal\",\n    contents: [\n      { type: \"text\", text: p.label, size: \"sm\", color: \"#555555\", flex: 3 },\n      { type: \"text\", text: `${p.price}.-`, size: \"sm\", color: \"#111111\", weight: \"bold\", align: \"end\", flex: 1 },\n    ],\n    margin: \"md\",\n  }));\n\n  const addonRows = addons.flatMap((a) => {\n    const mainRow = {\n      type: \"box\",\n      layout: \"horizontal\",\n      contents: [\n        { type: \"text\", text: `🔧 ${a.item}`, size: \"xs\", color: \"#666666\", flex: 3, wrap: true },\n        { type: \"text\", text: a.price, size: \"xs\", color: \"#ff334b\", weight: \"bold\", align: \"end\", flex: 1, adjustMode: \"shrink-to-fit\" },\n      ],\n      margin: \"sm\",\n    };\n\n    if (!a.note) return [mainRow];\n\n    return [\n      mainRow,\n      { type: \"text\", text: a.note, size: \"xxs\", color: \"#999999\", margin: \"xs\", wrap: true }\n    ];\n  });\n\n  return {\n    type: \"flex\",\n    altText: \"ตารางราคาล้างแอร์ 2026\",\n    contents: {\n      type: \"bubble\",\n      size: \"mega\",\n      header: {\n        type: \"box\",\n        layout: \"vertical\",\n        backgroundColor: headerColor,\n        paddingAll: \"lg\",\n        contents: [\n          { type: \"text\", text: \"❄️ ราคาล้างแอร์ติดผนัง\", weight: \"bold\", color: \"#ffffff\", size: \"lg\" },\n          { type: \"text\", text: \"อัปเดตปี 2026\", color: \"#ffffffcc\", size: \"xs\", margin: \"xs\" },\n        ],\n      },\n      body: {\n        type: \"box\",\n        layout: \"vertical\",\n        contents: [\n          { type: \"text\", text: \"ราคาเริ่มต้น (ล้างปกติ)\", weight: \"bold\", size: \"md\", color: \"#333333\" },\n          { type: \"separator\", margin: \"md\", color: \"#eeeeee\" },\n          ...priceRows,\n          { type: \"separator\", margin: \"lg\", color: \"#eeeeee\" },\n          {\n            type: \"box\",\n            layout: \"vertical\",\n            margin: \"lg\",\n            backgroundColor: \"#f7f7f7\",\n            cornerRadius: \"md\",\n            paddingAll: \"md\",\n            contents: [\n              { type: \"text\", text: \"📌 บริการเสริม & เงื่อนไข\", size: \"xs\", weight: \"bold\", color: \"#333333\" },\n              ...addonRows,\n              { type: \"separator\", margin: \"md\", color: \"#e0e0e0\" },\n              { type: \"text\", text: \"🛡️ รับประกันน้ำหยดหลังล้าง 30 วัน\", size: \"xs\", color: headerColor, weight: \"bold\", align: \"center\", margin: \"md\" },\n            ],\n          },\n        ],\n      },\n      footer: {\n        type: \"box\",\n        layout: \"vertical\",\n        spacing: \"sm\",\n        contents: [\n          { type: \"button\", style: \"primary\", color: headerColor, action: { type: \"uri\", label: \"จองคิวทันที\", uri: LIFF || \"https://liff.line.me/2008445752-IZ9iXrPC\" } },\n          { type: \"button\", style: \"secondary\", action: postbackAction(\"คุยกับแอดมิน\", \"MENU:TALK_ADMIN\") },\n        ],\n      },\n    },\n  };\n}\n\nfunction adminGateMenu() {\n  return {\n    type: \"text\",\n    text: \"เลือกหัวข้อติดต่อแอดมินครับ 👇\",\n    quickReply: {\n      items: [\n        { type: \"action\", action: postbackAction(\"ติดตามงาน\", \"ADMIN:TRACK\") },\n        { type: \"action\", action: postbackAction(\"แจ้งปัญหา\", \"ADMIN:ISSUE\") },\n        { type: \"action\", action: postbackAction(\"อื่นๆ\", \"ADMIN:OTHER\") },\n      ],\n    },\n  };\n}\n\nfunction adminAck(reason) {\n  return { type: \"text\", text: `รับเรื่องแล้วครับ (${reason}) แอดมินจะติดต่อกลับให้เร็วที่สุด\\nพิมพ์รายละเอียดเพิ่มได้เลย (ชื่อ/เบอร์/เลขงาน/ที่อยู่)` };\n}\n\nfunction bookMsg() {\n  const link = LIFF || \"https://liff.line.me/2008445752-IZ9iXrPC\";\n  return { type: \"text\", text: `📅 จองคิวออนไลน์ได้ที่นี่ครับ\\n${link}` };\n}\n\nfunction askAiIntro() {\n  return {\n    type: \"text\",\n    text: \"สวัสดีครับ 👋\\nสอบถามเบื้องต้นได้เลย เช่น ราคา / พื้นที่บริการ / รับซ่อมไหม / ค่าตรวจเช็ค/ประเมินหน้างานเท่าไร\\nค่าตรวจเช็ค/ประเมินหน้างาน เริ่มต้น 1,000 บาท กรณีเช็กแล้วไม่ซ่อม\\nถ้าต้องการจองคิว ประเมินหน้างาน หรือตามงาน ผมจะส่งต่อแอดมินให้ครับ\"\n  };\n}\n\n// ✅ IMPORTANT: compute once, return once, always carry context\nlet route = \"IGNORE\";\nlet replyPayload = null;\nlet pushPayload = null;\n\nif (!replyToken) {\n  // no reply token → ignore (still carry context)\n  return [{ json: { ...$json, route, replyPayload, pushPayload, cmd } }];\n}\n\nif (cmd === \"MENU:PRICE_CLEAN\") {\n  route = \"PRICE_SHOW\";\n  \n  // ✅ ข้อความประกาศปรับราคา\n  const announcementText = {\n    type: \"text\",\n    text: \"📢 ประกาศแจ้งปรับราคาบริการล้างแอร์\\nเนื่องจากต้นทุนในการเดินทางและการให้บริการปรับตัวสูงขึ้น ทางบริษัทขอแจ้งปรับราคาเริ่มต้นของบริการล้างแอร์ ดังนี้\"\n  };\n\n  const followUpText = {\n    type: \"text\",\n    text: \"หลังดูราคาแล้ว ถ้าต้องการสอบถามเบื้องต้น พิมพ์ถามได้เลย หรือกด “ติดต่อแอดมิน” ได้ทันทีค่ะ\\nค่าตรวจเช็ค/ประเมินหน้างาน เริ่มต้น 1,000 บาท กรณีเช็คแล้วไม่ซ่อม\"\n  };\n\n  // ส่ง array ที่มีทั้ง [ประกาศ, FlexMessage, ข้อความ]\n  replyPayload = { replyToken, messages: [announcementText, genPriceFlex(), followUpText] };\n\n} else if (cmd === \"MENU:BOOK\") {\n  route = \"BOOK\";\n  replyPayload = { replyToken, messages: [bookMsg()] };\n} else if (cmd === \"MENU:ASK_AI\") {\n  route = \"ASK_AI\";\n  replyPayload = { replyToken, messages: [askAiIntro()] };\n} else if (cmd === \"MENU:TALK_ADMIN\") {\n  route = \"ADMIN_MENU\";\n  replyPayload = { replyToken, messages: [adminGateMenu()] };\n} else {\n  const m = cmd.match(/^ADMIN:(TRACK|ISSUE|OTHER)$/);\n  if (m) {\n    route = \"ADMIN_PUSH\";\n    const reasonMap = { TRACK: \"ติดตามงาน\", ISSUE: \"แจ้งปัญหา\", OTHER: \"อื่นๆ\" };\n    const reason = reasonMap[m[1]] || m[1];\n\n    replyPayload = { replyToken, messages: [adminAck(reason)] };\n\n    const adminTo = String($json.ADMIN_TO || \"\").trim();\n    if (adminTo) {\n      const who = String($json.line_user_id || $json.platform_user_id || \"unknown\");\n      pushPayload = {\n        to: adminTo,\n        messages: [\n          { type: \"text\", text: `🔔 ลูกค้าขอคุยแอดมิน\\nหัวข้อ: ${reason}\\nผู้ใช้: ${who}\\nOA: ${$json.account_key || \"-\"}\\nเวลา: ${new Date().toLocaleString('th-TH')}` }\n        ],\n      };\n    }\n  }\n}\n\nreturn [{ json: { ...$json, route, replyPayload, pushPayload, cmd } }];"
      },
