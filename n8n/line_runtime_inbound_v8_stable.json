    {
      "parameters": {
        "jsCode": "const event = $json.event;\nreturn [{ json: {\n  request_id: $json.request_id,\n  received_at: $json.received_at,\n  line_context: { reply_token: event?.replyToken, user_id: event?.source?.userId, customer_message: event?.message?.text, message_id: event?.message?.id },\n  normalized_request: {\n    channel: 'line',\n    channelUserId: event?.source?.userId,\n    customerMessage: event?.message?.text,\n    sourceEvent: { replyToken: event?.replyToken, messageId: event?.message?.id, timestamp: event?.timestamp },\n    runtime: { requestId: $json.request_id, receivedAt: $json.received_at, mode: 'line_text_inbound' }\n  }\n}}];"
