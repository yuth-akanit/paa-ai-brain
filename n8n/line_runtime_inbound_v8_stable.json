    {
      "parameters": {
        "jsCode": "const decision = $json.decision || {};\nconst replyText = decision.customer_reply?.trim() || '';\n\n// แก้จุดนี้: ถ้าใน $json ไม่มี ให้ไปควักมาจาก Node ต้นทางโดยตรงครับ\nconst lineCtx = $json.line_context || $node[\"normalize_line_event\"].json.line_context || {};\nconst requestId = $json.request_id || $node[\"normalize_line_event\"].json.request_id;\n\nreturn [{\n  json: {\n    request_id: requestId,\n    reply_api_payload: replyText ? { \n      replyToken: lineCtx.reply_token, \n      messages: [{ type: 'text', text: replyText }] \n    } : null,\n    admin_notify_payload: {\n      request_id: requestId,\n      source: 'v8_final_fix',\n      customer_message: lineCtx.customer_message,\n      intent: decision.intent,\n      summary: decision.admin_summary?.summary || 'AI detected handoff required'\n    }\n  }\n}];\n"
      },
