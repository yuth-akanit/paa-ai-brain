    {
      "parameters": {
        "jsCode": "// ดึงข้อมูล Input ดั้งเดิมที่ยังไม่ถูก HTTP Request วางทับ\nconst originalInput = $('has_minimum_normalized_fields').first().json;\nconst rpc = Array.isArray($json.data) ? $json.data[0] : ($json.data || $json);\n\nconst gate = {\n  found_thread: !!rpc?.thread_id,\n  thread_id: rpc?.thread_id || null,\n  case_id: rpc?.case_id || null,\n  thread_state: rpc?.thread_state || 'ai_active',\n  ai_blocked: !!rpc?.ai_blocked,\n  admin_active: !!rpc?.admin_active,\n  reason_code: rpc?.reason_code || 'no_open_thread',\n  should_call_ai: !(rpc?.ai_blocked === true)\n};\n\nconst humanOwned = gate.ai_blocked === true || [\"handed_off\", \"closed\"].includes(gate.thread_state);\nconst allowAi = !humanOwned;\n\n// ประกอบร่างใหม่ให้มี threadId แล้วนำไปส่งให้ AI ต่อไป\nconst normalized_request = { ...originalInput.normalized_request, threadId: gate.thread_id };\n\nreturn [{\n  json: {\n    ...originalInput,\n    normalized_request,\n    gate,\n    gate_decision: { allow_ai: allowAi, reason: humanOwned ? \"HUMAN_OWNED_BLOCK\" : \"AI_ALLOWED\" }\n  }\n}];\n"
      },
      "id": "569fa9f5-ffa2-4aaa-9385-3714df466977",
      "name": "decide_gate_policy",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3776,
        3392
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    ...$json,\n    route: 'skip_reply',\n    decision: { ok: true, recommended_action: 'skip_reply', customer_reply: '' },\n    admin_notify_payload: {\n      request_id: $json.request_id,\n      source: 'v7_final_skip',\n      customer_message: $json.line_context.customer_message,\n      reason: $json.gate_decision.reason,\n      summary: `AI silent (Handover Active) | Thread: ${$json.gate.thread_id}`,\n      thread_id: $json.gate.thread_id\n    }\n  }\n}];"
      },
