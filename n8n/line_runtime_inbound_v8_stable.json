      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\nif (!body || !Array.isArray(body.events) || body.events.length === 0) {\n  return [{ json: { ok: false, stage: 'extract_first_event', should_stop: true } }];\n}\nconst event = body.events[0];\nreturn [{ json: { ok: true, request_id: `rt_${Date.now()}`, received_at: new Date().toISOString(), event } }];"
